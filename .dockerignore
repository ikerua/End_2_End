# ── .dockerignore (raíz del proyecto) ─────────────────────────────────────────
# Usado cuando el contexto de build es la raíz del proyecto (imágenes bundled).
# Evita enviar al Docker daemon cosas grandes innecesarias.

# Modelos que NO queremos incluir (solo models/base_hf se incluye en bundled)
models/exported_hf/
models/checkpoints/
whisper/
whisper.cpp/

# Entrenamiento, demos y scripts
training/
demo/
scripts/
src/

# Documentación y archivados
docs/
_archive/

# Python cache
**/__pycache__/
**/*.pyc
**/*.pyo
**/*.pyd
**/.pytest_cache/
**/*.egg-info/

# Entornos virtuales
.venv/
venv/
env/

# Git y herramientas de desarrollo
.git/
.github/
.gitignore
.gemini/

# Logs
app/logs/
**/logs/*.jsonl

# Misc
*.md
*.zip
*.bin
